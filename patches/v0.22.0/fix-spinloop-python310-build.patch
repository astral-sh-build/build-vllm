From 7334b38a769af8f4226de8573d2102dc3fcbecad Mon Sep 17 00:00:00 2001
Subject: fix: avoid spinloop stable ABI on Python 3.10

Upstream: https://github.com/vllm-project/vllm/pull/43131

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 35171b473d34..6bdd22640c1b 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -118,11 +118,17 @@ set(SPINLOOP_COMPILE_FLAGS "")
 if(CMAKE_SYSTEM_PROCESSOR MATCHES "x86_64|amd64")
   list(APPEND SPINLOOP_COMPILE_FLAGS "-mmwaitx")
 endif()
+
+set(SPINLOOP_SABI_ARGS "")
+if(Python_VERSION VERSION_GREATER_EQUAL 3.11)
+  list(APPEND SPINLOOP_SABI_ARGS USE_SABI 3.11)
+endif()
+
 define_extension_target(
   spinloop
   DESTINATION vllm
   LANGUAGE CXX
   SOURCES ${VLLM_SPINLOOP_EXT_SRC}
   COMPILE_FLAGS ${SPINLOOP_COMPILE_FLAGS}
-  USE_SABI 3.11
+  ${SPINLOOP_SABI_ARGS}
   WITH_SOABI)
